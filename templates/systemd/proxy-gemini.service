[Unit]
Description=Squad-Mind Gemini Proxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/.npm-global/bin/llm-cli-proxy --provider gemini --port 3457 --host 127.0.0.1 --workspace %h/Documents/Home-Brain
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
