# Hermes Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.

# ==================================================================
# MODE: Choose how Hermes connects to LLM providers
# ==================================================================
# Option A — Direct API Keys (default):
#   Set provider API keys below. Hermes calls provider APIs directly.
#   Best for: users with API credits, no CLI subscriptions.
#
# Option B — CLI Proxy Mode:
#   Use llm-cli-proxy to route through Claude Code / Gemini CLI.
#   Best for: users with Claude Max or Gemini Advanced subscriptions.
#   Set PROXY_MODE=true and configure proxy ports below.
#   See docs/PROXY_SETUP.md for details.
# ==================================================================
PROXY_MODE=false

# ------------------------------------------------------------------
# Proxy Configuration (used only when PROXY_MODE=true)
# ------------------------------------------------------------------
# llm-cli-proxy runs local OpenAI-compatible endpoints.
# Install: npm install -g llm-cli-proxy
# Each agent can have its own proxy port for isolation.
CLAUDE_PROXY_URL=http://127.0.0.1:3456/v1
CLAUDE_PROXY_KEY=local-proxy
GEMINI_PROXY_URL=http://127.0.0.1:3457/v1
GEMINI_PROXY_KEY=local-proxy

# ------------------------------------------------------------------
# Anthropic (Claude) — Required for orchestrator (direct mode only)
# Get key: https://console.anthropic.com/
# ------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# ------------------------------------------------------------------
# Google Gemini — Used by researcher, financial, health agents (direct mode only)
# Get key: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------------
GOOGLE_API_KEY=AIza...

# ------------------------------------------------------------------
# Kimi (Moonshot) — Used by coder agent (direct mode only)
# Get key: https://platform.moonshot.cn/
# ------------------------------------------------------------------
KIMI_API_KEY=sk-...

# ------------------------------------------------------------------
# OpenRouter — Used by reasoning mentor (DeepSeek-R1, etc.)
# Get key: https://openrouter.ai/keys
# ------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...

# ------------------------------------------------------------------
# OpenAI — Optional fallback
# Get key: https://platform.openai.com/api-keys
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------------
# Ollama (local models) — Optional for on-device inference
# No API key needed if running locally
# ------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------------
# Telegram Bot Tokens — One per enabled delivery bot
# Get token from @BotFather: https://t.me/botfather
# ------------------------------------------------------------------
TELEGRAM_BOT_TOKEN_HERMES=...
TELEGRAM_BOT_TOKEN_HEPHAESTUS=...
TELEGRAM_BOT_TOKEN_CLIO=...
TELEGRAM_BOT_TOKEN_ATHENA=...
TELEGRAM_BOT_TOKEN_ASCLEPIUS=...
TELEGRAM_BOT_TOKEN_ARGUS=...

# ------------------------------------------------------------------
# Telegram Chat IDs — Where bots send messages
# Get your ID: https://t.me/userinfobot
# ------------------------------------------------------------------
TELEGRAM_CHAT_ID=...

# ------------------------------------------------------------------
# Vault & Runtime Paths (overridden by setup_answers.yaml)
# ------------------------------------------------------------------
VAULT_PATH=/home/user/Documents/Home-Brain
HERMES_HOME=/home/user/.hermes
