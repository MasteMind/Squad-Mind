# Hermes Environment Configuration
# Copy this file to .env and fill in your actual API keys.
# NEVER commit .env to git.

# ------------------------------------------------------------------
# Anthropic (Claude) — Required for orchestrator
# Get key: https://console.anthropic.com/
# ------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# ------------------------------------------------------------------
# Google Gemini — Used by researcher, financial, health agents
# Get key: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------------
GOOGLE_API_KEY=AIza...

# ------------------------------------------------------------------
# Kimi (Moonshot) — Used by coder agent
# Get key: https://platform.moonshot.cn/
# ------------------------------------------------------------------
KIMI_API_KEY=sk-...

# ------------------------------------------------------------------
# OpenRouter — Used by reasoning mentor (DeepSeek-R1, etc.)
# Get key: https://openrouter.ai/keys
# ------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...

# ------------------------------------------------------------------
# OpenAI — Optional fallback
# Get key: https://platform.openai.com/api-keys
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------------
# Ollama (local models) — Optional for on-device inference
# No API key needed if running locally
# ------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------------
# Telegram Bot Tokens — One per enabled delivery bot
# Get token from @BotFather: https://t.me/botfather
# ------------------------------------------------------------------
TELEGRAM_BOT_TOKEN_HERMES=...
TELEGRAM_BOT_TOKEN_HEPHAESTUS=...
TELEGRAM_BOT_TOKEN_CLIO=...
TELEGRAM_BOT_TOKEN_ATHENA=...
TELEGRAM_BOT_TOKEN_ASCLEPIUS=...
TELEGRAM_BOT_TOKEN_ARGUS=...

# ------------------------------------------------------------------
# Telegram Chat IDs — Where bots send messages
# Get your ID: https://t.me/userinfobot
# ------------------------------------------------------------------
TELEGRAM_CHAT_ID=...

# ------------------------------------------------------------------
# Vault & Runtime Paths (overridden by setup_answers.yaml)
# ------------------------------------------------------------------
VAULT_PATH=/home/user/Documents/Home-Brain
HERMES_HOME=/home/user/.hermes
